# Backend Configuration
PORT=8000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# PocketBase Configuration
POCKETBASE_URL=http://localhost:8090
# When PB is separate: https://pb_goldfisch.iwishihadthis.com
POCKETBASE_ENCRYPTION_KEY=your-secret-key-here-change-this-in-production
# Host port for PB (default 8090). Use 18090 if 8090 is in use.
# POCKETBASE_PORT=18090

# DragonflyDB Configuration
DRAGONFLY_URL=redis://localhost:6379

# PostHog Analytics
POSTHOG_API_KEY=phc_your_posthog_project_api_key_here
POSTHOG_HOST=https://app.posthog.com

# SendGrid Email Service
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@yourapp.com
SENDGRID_FROM_NAME=Your App Name

# Frontend Environment Variables (for frontend/.env)
VITE_POCKETBASE_URL=http://localhost:8090
VITE_PUBLIC_POSTHOG_KEY=phc_your_posthog_project_api_key_here
VITE_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Google Calendar OAuth (for Connect Google Calendar feature)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Redirect URI - must match Google Cloud Console. Use your app URL + /api/calendar/callback
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3000/api/calendar/callback

# Coolify Deployment (uncomment when deploying)
# COOLIFY_URL=https://your-app.coolify.io